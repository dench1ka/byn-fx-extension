{
  "manifest_version": 3,
  "name": "BYN·FX — Конвертер цен для av.by и Kufar",
  "version": "1.0.0",
  "description": "Конвертирует цены BYN в любую валюту по курсу Нацбанка РБ. Работает на av.by и kufar.by. Справочный инструмент для личного пользования.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://av.by/*",
    "https://*.av.by/*",
    "https://kufar.by/*",
    "https://*.kufar.by/*",
    "https://api.nbrb.by/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://av.by/*",
        "https://*.av.by/*",
        "https://kufar.by/*",
        "https://*.kufar.by/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
